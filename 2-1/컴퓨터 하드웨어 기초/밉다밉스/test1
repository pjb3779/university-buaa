main:
    li $v0, 5              # Read integer syscall
    syscall
    move $t0, $v0          # 첫 번째 정수를 $t0에 저장

    li $v0, 5              # Read integer syscall
    syscall
    move $t1, $v0          # 두 번째 정수를 $t1에 저장

# 최대 공약수 계산 (유클리드 알고리즘)
compute_gcd:
    beq $t1, 0, end_gcd    # $t1이 0이면 종료
    div $t0, $t1           # $t0를 $t1로 나눔
    mfhi $t2               # 나머지를 $t2에 저장
    move $t0, $t1          # $t0에 $t1 값을 이동
    move $t1, $t2          # $t1에 나머지($t2) 이동
    j compute_gcd          # 반복

end_gcd:
    move $a0, $t0          # 최대 공약수를 $a0에 저장
    li $v0, 1              # Print integer syscall
    syscall

    li $v0, 4              # Print newline
    syscall

# 프로그램 종료
    li $v0, 10             # Exit syscall
    syscall